# Copy values into your Hermes profile environment or shell.
# Do not commit real app secrets.

FEISHU_APP_ID=cli_xxx
FEISHU_APP_SECRET=xxx
FEISHU_BOT_NAME=1号Hermes

HERMES_FEISHU_A2A_REGISTRY_FILE=/absolute/path/to/agents.local.json
